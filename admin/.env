# DarkSword Admin 安全配置
# 生产环境请修改以下默认值

# JWT 密钥（生产环境必须修改）
SECRET_KEY=darksword_secret_key_2026_security_admin_panel

# JWT 令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS 允许来源（逗号分隔，生产环境限制为具体域名）
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000

# API 限流配置
RATE_LIMIT=100/minute
AUTH_RATE_LIMIT=5/minute
